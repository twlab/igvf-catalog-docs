{
  "$schema": "https://mintlify.com/schema.json",
  "name": "IGVF Catalog",
  "logo": {
    "dark": "/logo/dark.png",
    "light": "/logo/light.png"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373",
    "anchors": {
      "from": "#0D9373",
      "to": "#07C983"
    }
  },
  "topbarCtaButton": {
    "name": "Catalog",
    "url": "https://catalog.igvf.org"
  },
  "api": {
    "openapi": "openapi/catalog-dev.openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required"
    }
  },
  "tabs": [
    {
      "name": "Documentation",
      "url": "introduction"
    },
    {
      "name": "API Reference",
      "url": "api-reference"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": [
        "introduction",
        "using-search"
      ]
    },
    {
      "group": "Nodes",
      "pages": [
        "nodes/gene",
        "nodes/variant",
        "nodes/protein",
        "nodes/transcript",
        "nodes/disease",
        "nodes/ontologies"
      ]
    },
    {
      "group": "Regions",
      "pages": [
        "region/region-page",
        "region/variant-dashboard"
      ]
    },
    {
      "group": "Data Sources",
      "pages": [
        "data-sources/index",
        "data-sources/files-filesets",
        "data-sources/field-lineage/index"
      ]
    },
    {
      "group": "API Reference",
      "openapi": "openapi/catalog-dev.openapi.json",
      "pages": [
        "api-reference/introduction"
      ]
    }
  ]
}
