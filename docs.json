{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "IGVF Catalog",
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0D9373",
    "light": "#07C983",
    "dark": "#0D9373"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Catalog",
      "href": "https://catalog.igvf.org"
    }
  },
  "api": {
    "openapi": "openapi/catalog-dev.openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"],
      "defaults": "required"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "using-search"]
          },
          {
            "group": "Nodes",
            "pages": [
              "nodes/gene",
              "nodes/variant",
              "nodes/protein",
              "nodes/transcript",
              "nodes/disease",
              "nodes/ontologies"
            ]
          },
          {
            "group": "Regions",
            "pages": ["region/region-page", "region/variant-dashboard"]
          },
          {
            "group": "Data Sources",
            "pages": [
              "data-sources/index",
              "data-sources/files-filesets",
              "data-sources/field-lineage/index"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/catalog-dev.openapi.json",
        "pages": ["api-reference/introduction"]
      }
    ]
  }
}
